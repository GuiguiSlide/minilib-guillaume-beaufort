// tsconfig.json
{
"compilerOptions": {
    "target": "ES2022", // version JS générée
    "module": "NodeNext", // format de modules (ESM)
    "moduleResolution": "NodeNext",
    "outDir": "./dist", // dossier de sortie JS compilé
    "rootDir": "./src", // dossier source TS
    "strict": true, // active toutes les vérifications strictes
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "checkJs": true,
    "allowJs": true

},
"include": ["src/**/*"],
"exclude": ["node_modules", "dist"]
}